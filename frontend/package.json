{
  "name": "pomodoro-table-frontend",
  "private": true,
  "version": "0.1.0",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "desktop:build": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.8.1",
    "echarts": "^5.6.0",
    "element-plus": "^2.9.4",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1",
    "vite": "^6.1.0"
  },
  "build": {
    "appId": "com.pomodorotable.desktop",
    "productName": "PomodoroTable",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "PomodoroTable-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "PomodoroTable"
    }
  }
}