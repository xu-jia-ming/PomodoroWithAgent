{
  "name": "pomodoro-table-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "PomodoroTable desktop client for Windows",
  "author": "PomodoroTable Team",
  "license": "UNLICENSED",
  "homepage": "https://github.com/jmxjiamingxu/PomodoroTable",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "vite build",
    "build:backend": "node scripts/build-backend.cjs",
    "mobile:env:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-mobile-env.ps1",
    "mobile:sync-deps": "node scripts/sync-mobile-deps.cjs",
    "mobile:sync-backend": "node scripts/sync-mobile-backend.cjs",
    "mobile:sync": "npm run build && npm run mobile:sync-backend && npm run mobile:sync-deps && npx cap sync android",
    "mobile:open": "npx cap open android",
    "mobile:build:debug": "cd android && gradlew.bat assembleDebug",
    "mobile:build:release": "cd android && gradlew.bat assembleRelease",
    "mobile:bundle:release": "cd android && gradlew.bat bundleRelease",
    "desktop:prepare": "node scripts/prepare-desktop-build.cjs",
    "preview": "vite preview",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "desktop:build": "npm run build && npm run build:backend && npm run desktop:prepare && electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.8.1",
    "echarts": "^5.6.0",
    "element-plus": "^2.9.4",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^7.5.0",
    "@capacitor/core": "^8.1.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.1.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.pomodorotable.desktop",
    "productName": "PomodoroTable",
    "copyright": "Copyright © 2026 PomodoroTable Team",
    "disableDefaultIgnoredFiles": true,
    "directories": {
      "buildResources": "build",
      "output": "release-build"
    },
    "extraResources": [
      {
        "from": "app-dist",
        "to": "app-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/dist-desktop/pomodoro-backend.exe",
        "to": "backend/pomodoro-backend.exe"
      }
    ],
    "files": [
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "PomodoroTable-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "PomodoroTable",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
